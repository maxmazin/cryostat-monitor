[Unit]
Description=cryostat-monitor nightly PostgreSQL backup
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=cryo
# Optional overrides (CRYO_BACKUP_DIR, CRYO_BACKUP_KEEP_DAYS, …). The `-` makes
# the file optional so the unit still runs with defaults if it's absent.
EnvironmentFile=-/etc/cryostat-monitor/backup.env
ExecStart=/opt/cryostat-monitor/scripts/pg_backup.sh
