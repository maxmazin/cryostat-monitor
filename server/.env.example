# Ingest service environment. Copy to .env (gitignored) and fill in.
# On labmanager this lives at /etc/cryostat-monitor/ingest.env (see systemd unit).

# Local Unix-socket peer auth — no password (matches docs/deployment.md, where
# the OS user and PG role are both `cryo`).
CRYO_DB_DSN=postgresql:///cryo?host=/var/run/postgresql
# TCP alternative — requires pg_hba md5/scram and a password baked into the DSN:
# CRYO_DB_DSN=postgresql://cryo:PASSWORD@127.0.0.1:5432/cryo

# Per-host bearer tokens -> fridge. JSON object. Use long random tokens in prod;
# prefer CRYO_TOKENS_FILE over inlining if you keep secrets in a file.
CRYO_TOKENS={"dev-token-bluefors_1":"bluefors_1"}
# CRYO_TOKENS_FILE=/etc/cryostat-monitor/tokens.json

# Bearer tokens allowed to set maintenance mutes (OpenClaw, humans). JSON array.
# If empty/unset, /maintenance is refused (fail-closed) — it must NOT be open,
# since a mute suppresses safety alerts (§2.1).
CRYO_MAINTENANCE_TOKENS=["dev-maintenance-token"]
# CRYO_MAINTENANCE_TOKENS_FILE=/etc/cryostat-monitor/maintenance_tokens.json

# Cap on maintenance mute duration in minutes (§7).
CRYO_MAX_MAINTENANCE_MINUTES=720
