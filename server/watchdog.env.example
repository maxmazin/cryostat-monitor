# Watchdog environment. Copy to watchdog.env (gitignored) and fill in.
# On labmanager this lives at /etc/cryostat-monitor/watchdog.env (see the
# systemd unit). The watchdog reads the SAME database the ingest service writes.

# Same database as the ingest service (§8 reads readings/last_seen/maintenance,
# writes alert_state). Local Unix-socket peer auth — no password.
CRYO_DB_DSN=postgresql:///cryo?host=/var/run/postgresql

# Dedicated incoming webhook for alerts — its OWN Slack app, SEPARATE from
# OpenClaw's bot (§2.1). Alerts must fire even if OpenClaw is completely dead.
# The env var NAME is configurable in fridges.yaml (slack.webhook_url_env).
CRYO_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/REPLACE/WITH/REAL

# healthchecks.io dead-man's switch (§5/§8). The watchdog GETs this every loop;
# configure healthchecks to alert if pings stop for >2 min. Overrides the value
# in fridges.yaml. Leave unset to disable heartbeating (NOT recommended in prod).
CRYO_HEALTHCHECKS_URL=https://hc-ping.com/REPLACE-WITH-UUID

# Optional: path to the fridge lifecycle config. Defaults to server/config/
# fridges.yaml relative to the package, which is correct under systemd.
# CRYO_FRIDGES_CONFIG=/opt/cryostat-monitor/server/config/fridges.yaml
